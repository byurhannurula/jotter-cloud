{
  "name": "jotter-cloud",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Self-hosted Cloudflare Worker for Jotter — drafts sync (R2) and read-only sharing (D1).",
  "engines": {
    "node": ">=22"
  },
  "cloudflare": {
    "bindings": {
      "SYNC_TOKEN": {
        "description": "Shared secret that protects your notes. Generate one in Jotter (Settings -> Sync -> Generate token) and paste the SAME value here. It is the only thing guarding sync and sharing - treat it like a password. Do not leave this blank."
      }
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "bash test/smoke.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,jsonc,md,css,html,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241120.0",
    "@eslint/js": "^9.15.0",
    "@types/markdown-it": "^14.1.2",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0",
    "wrangler": "^4.0.0"
  }
}
