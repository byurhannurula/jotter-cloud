    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "hono": "^4.6.0",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241120.0",
    "@eslint/js": "^9.15.0",
    "@types/markdown-it": "^14.1.2",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0",
    "wrangler": "^4.0.0"
  }
}
